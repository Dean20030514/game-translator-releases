{
    "$schema": "https://github.com/Dean20030514/Multi-Engine-Game-Translator",
    "_comment": "Ren'Py 汉化工具配置文件示例。复制为 renpy_translate.json 放在游戏目录下即可使用。",

    "provider": "xai",
    "api_key_env": "XAI_API_KEY",
    "model": "grok-4-1-fast-reasoning",
    "genre": "adult",

    "workers": 5,
    "rpm": 600,
    "rps": 10,
    "timeout": 180,
    "temperature": 0.1,
    "max_chunk_tokens": 4000,

    "_comment_target_lang": "Round 52 C4 BREAKING: target_lang field retired (always zh).",
    "exclude": ["tl/*", "*.bak"],
    "dict": [],
    "min_dialogue_density": 0.20,

    "copy_assets": false,
    "patch_font": false
}
